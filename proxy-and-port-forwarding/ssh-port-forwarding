#!/bin/bash
set -euo pipefail

# See ssh-port-forwarding.README.md for details

source "/etc/${0##*/}.conf"

CONFIG_FILE="$(mktemp /tmp/ssh-config.XXXXXX)"
cleanup() {
    rm -f "$CONFIG_FILE"
}
trap cleanup EXIT

BEST_JUMP_HOST=""


# -------------------------
# Select best jump host
# -------------------------
if [[ -n "${SSH_JUMP_HOSTS:-}" ]]; then

    BEST_JUMP_HOST="$(
        check-ssh-speed \
            $CHECK_SSH_SPEED_OPTIONS \
            -u "$SSH_JUMP_USER" \
            -i "$SSH_JUMP_KEY_FILE" \
            $SSH_JUMP_HOSTS \
        | grep OK \
        | LANG=C sort -k3,3 -nr \
        | head -n1 \
        | cut -d ' ' -f2
    )"

    if [[ -z "$BEST_JUMP_HOST" ]]; then
        echo "Can not connect to any jump host" >&2
        exit 1
    fi

    echo "Selected best jump host: $BEST_JUMP_HOST"
fi


# -------------------------
# Build SSH config
# -------------------------
cat > "$CONFIG_FILE" <<EOF
Host jump
    HostName ${BEST_JUMP_HOST:-empty}
    User ${SSH_JUMP_USER:-empty}
    IdentityFile ${SSH_JUMP_KEY_FILE:-empty}
    StrictHostKeyChecking no
    UserKnownHostsFile /dev/null

Host target
    HostName $SSH_HOST
    User $SSH_USER
    IdentityFile $SSH_KEY_FILE
    StrictHostKeyChecking no
    UserKnownHostsFile /dev/null
EOF

if [[ -n "${BEST_JUMP_HOST:-}" ]]; then
cat >> "$CONFIG_FILE" <<EOF
    ProxyJump jump
EOF
fi


# -------------------------
# Run SSH tunnel
# -------------------------
ssh -F "$CONFIG_FILE" \
    -N \
    -o ExitOnForwardFailure=yes \
    -o ServerAliveInterval=60 \
    -L "$LOCAL_BIND_ADDRESS:$LOCAL_PORT:$SSH_HOST:$REMOTE_PORT" \
    target \
    2>&1 | egrep -v 'Warning: Permanently added .* to the list of known hosts'

